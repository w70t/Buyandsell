# ==========================================================================
# Souqna — environment configuration
# Copy this file to `.env` and adjust. NEVER commit the real `.env`.
# The same file works on Raspberry Pi and on a VPS — only the values change.
# ==========================================================================

# ---- App ----
APP_NAME=Souqna
APP_ENV=production            # development | production
SECRET_KEY=change-me-to-a-long-random-string-openssl-rand-hex-32
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30

# CORS: comma-separated origins allowed to call the API (Flutter web / admin).
# "*" is fine while testing on the Raspberry Pi LAN.
CORS_ORIGINS=*

# Public base URL the API is reachable at (used to build absolute image URLs).
# Pi (LAN):     http://192.168.1.50:8080
# Cloudflare:   https://souqna.example.com
PUBLIC_BASE_URL=http://localhost:8080

# ---- Database (PostgreSQL) ----
POSTGRES_USER=souqna
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=souqna
# Used by the API container to reach the db service inside docker-compose:
DATABASE_URL=postgresql+asyncpg://souqna:change-me-strong-db-password@db:5432/souqna

# ---- File storage ----
# local  -> files saved on disk (simplest for Raspberry Pi)
# minio  -> S3-compatible object storage (scales to VPS/cloud without app changes)
STORAGE_BACKEND=local
UPLOAD_DIR=/data/uploads
MAX_UPLOAD_MB=8

# MinIO / S3 (only needed when STORAGE_BACKEND=minio)
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=souqna
MINIO_SECRET_KEY=change-me-minio-secret
MINIO_BUCKET=souqna-media
MINIO_SECURE=false

# ---- Rate limiting ----
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_AUTH=10/minute

# ---- Redis (optional) ----
# Empty = in-memory rate-limit counters (fine for 1 worker on the Pi).
# Set when scaling to multiple workers/hosts, e.g. redis://redis:6379/0
# and start the service with: docker compose --profile redis up -d
REDIS_URL=

# ---- Moderation ----
# A listing is hidden automatically once it collects this many open reports.
REPORTS_AUTO_HIDE_THRESHOLD=5

# ---- Telegram admin notifications (optional) ----
# Create a bot with @BotFather, put its token here; get your chat id from @userinfobot.
# Leave empty to disable — the app works fine without it.
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT_ID=

# ---- Web (SSR) cookies ----
# Set true once the site is served over HTTPS (VPS + domain).
COOKIE_SECURE=false

# ---- Seed admin (created on first boot if it doesn't exist) ----
ADMIN_PHONE=07700000000
ADMIN_NAME=Admin
ADMIN_PASSWORD=change-me-admin-password
